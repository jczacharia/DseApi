{
  "compileOnSave": false,
  "compilerOptions": {
    "experimentalDecorators": true,
    "importHelpers": true,
    "isolatedModules": true,
    "module": "preserve",
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "ES2022",
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "#api/*": ["./ui/app/api/*.ts"],
      "#core/*": ["./ui/app/core/*.ts"],
      "#features/*": ["./ui/app/features/*.ts"],
      "#shared/*": ["./ui/app/shared/*.ts"],
      "#sources/*": ["./ui/app/sources/*.ts"],
      "#testing/*": ["./ui/testing/*.ts"],
      "@spartan-ng/helm/accordion": ["./ui/app/ui/accordion/src/index.ts"],
      "@spartan-ng/helm/alert": ["./ui/app/ui/alert/src/index.ts"],
      "@spartan-ng/helm/alert-dialog": ["./ui/app/ui/alert-dialog/src/index.ts"],
      "@spartan-ng/helm/aspect-ratio": ["./ui/app/ui/aspect-ratio/src/index.ts"],
      "@spartan-ng/helm/autocomplete": ["./ui/app/ui/autocomplete/src/index.ts"],
      "@spartan-ng/helm/avatar": ["./ui/app/ui/avatar/src/index.ts"],
      "@spartan-ng/helm/badge": ["./ui/app/ui/badge/src/index.ts"],
      "@spartan-ng/helm/breadcrumb": ["./ui/app/ui/breadcrumb/src/index.ts"],
      "@spartan-ng/helm/button": ["./ui/app/ui/button/src/index.ts"],
      "@spartan-ng/helm/button-group": ["./ui/app/ui/button-group/src/index.ts"],
      "@spartan-ng/helm/calendar": ["./ui/app/ui/calendar/src/index.ts"],
      "@spartan-ng/helm/card": ["./ui/app/ui/card/src/index.ts"],
      "@spartan-ng/helm/carousel": ["./ui/app/ui/carousel/src/index.ts"],
      "@spartan-ng/helm/checkbox": ["./ui/app/ui/checkbox/src/index.ts"],
      "@spartan-ng/helm/collapsible": ["./ui/app/ui/collapsible/src/index.ts"],
      "@spartan-ng/helm/combobox": ["./ui/app/ui/combobox/src/index.ts"],
      "@spartan-ng/helm/command": ["./ui/app/ui/command/src/index.ts"],
      "@spartan-ng/helm/context-menu": ["./ui/app/ui/context-menu/src/index.ts"],
      "@spartan-ng/helm/date-picker": ["./ui/app/ui/date-picker/src/index.ts"],
      "@spartan-ng/helm/dialog": ["./ui/app/ui/dialog/src/index.ts"],
      "@spartan-ng/helm/drawer": ["./ui/app/ui/drawer/src/index.ts"],
      "@spartan-ng/helm/dropdown-menu": ["./ui/app/ui/dropdown-menu/src/index.ts"],
      "@spartan-ng/helm/empty": ["./ui/app/ui/empty/src/index.ts"],
      "@spartan-ng/helm/field": ["./ui/app/ui/field/src/index.ts"],
      "@spartan-ng/helm/hover-card": ["./ui/app/ui/hover-card/src/index.ts"],
      "@spartan-ng/helm/input": ["./ui/app/ui/input/src/index.ts"],
      "@spartan-ng/helm/input-group": ["./ui/app/ui/input-group/src/index.ts"],
      "@spartan-ng/helm/input-otp": ["./ui/app/ui/input-otp/src/index.ts"],
      "@spartan-ng/helm/item": ["./ui/app/ui/item/src/index.ts"],
      "@spartan-ng/helm/kbd": ["./ui/app/ui/kbd/src/index.ts"],
      "@spartan-ng/helm/label": ["./ui/app/ui/label/src/index.ts"],
      "@spartan-ng/helm/menubar": ["./ui/app/ui/menubar/src/index.ts"],
      "@spartan-ng/helm/native-select": ["./ui/app/ui/native-select/src/index.ts"],
      "@spartan-ng/helm/navigation-menu": ["./ui/app/ui/navigation-menu/src/index.ts"],
      "@spartan-ng/helm/pagination": ["./ui/app/ui/pagination/src/index.ts"],
      "@spartan-ng/helm/popover": ["./ui/app/ui/popover/src/index.ts"],
      "@spartan-ng/helm/progress": ["./ui/app/ui/progress/src/index.ts"],
      "@spartan-ng/helm/radio-group": ["./ui/app/ui/radio-group/src/index.ts"],
      "@spartan-ng/helm/resizable": ["./ui/app/ui/resizable/src/index.ts"],
      "@spartan-ng/helm/scroll-area": ["./ui/app/ui/scroll-area/src/index.ts"],
      "@spartan-ng/helm/select": ["./ui/app/ui/select/src/index.ts"],
      "@spartan-ng/helm/separator": ["./ui/app/ui/separator/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./ui/app/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/sidebar": ["./ui/app/ui/sidebar/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./ui/app/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/slider": ["./ui/app/ui/slider/src/index.ts"],
      "@spartan-ng/helm/sonner": ["./ui/app/ui/sonner/src/index.ts"],
      "@spartan-ng/helm/spinner": ["./ui/app/ui/spinner/src/index.ts"],
      "@spartan-ng/helm/switch": ["./ui/app/ui/switch/src/index.ts"],
      "@spartan-ng/helm/table": ["./ui/app/ui/table/src/index.ts"],
      "@spartan-ng/helm/tabs": ["./ui/app/ui/tabs/src/index.ts"],
      "@spartan-ng/helm/textarea": ["./ui/app/ui/textarea/src/index.ts"],
      "@spartan-ng/helm/toggle": ["./ui/app/ui/toggle/src/index.ts"],
      "@spartan-ng/helm/toggle-group": ["./ui/app/ui/toggle-group/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./ui/app/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/typography": ["./ui/app/ui/typography/src/index.ts"],
      "@spartan-ng/helm/utils": ["./ui/app/ui/utils/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictStandalone": true,
    "strictTemplates": true,
    "extendedDiagnostics": {
      "defaultCategory": "error"
    }
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
