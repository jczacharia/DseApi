{
  "name": "dse",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx --yes -p node@22.23.0 -p npm@10 -c \"ng serve\"",
    "ci": "npx --yes -p node@22.23.0 -p npm@10 -c \"npm ci --no-audit\"",
    "build": "npx --yes -p node@22.23.0 -p npm@10 -c \"ng build\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress",
    "lint": "ng lint",
    "fix": "eslint --fix ./src/Dse.Ui && prettier --write ./src/Dse.Ui",
    "prepare": "husky"
  },
  "private": true,
  "type": "module",
  "lint-staged": {
    "*.{ts,js,html}": [
      "eslint --fix"
    ],
    "*.{ts,js,html,json,css,scss,md,svg}": [
      "prettier --write"
    ]
  },
  "imports": {
    "#api/*": "./ui/app/api/*.ts",
    "#core/*": "./ui/app/core/*.ts",
    "#features/*": "./ui/app/features/*.ts",
    "#shared/*": "./ui/app/shared/*.ts",
    "#sources/*": "./ui/app/sources/*.ts",
    "#testing/*": "./ui/testing/*.ts",
    "#ui/*": "./ui/ui/*.ts",
    "#environment": {
      "test": "./ui/environments/environment-test.ts",
      "development": "./ui/environments/environment-development.ts",
      "default": "./ui/environments/environment.ts"
    }
  },
  "dependencies": {
    "@angular/aria": "22.1.0-next.1",
    "@angular/cdk": "22.1.0-next.1",
    "@angular/common": "22.1.0-next.1",
    "@angular/compiler": "22.1.0-next.1",
    "@angular/core": "22.1.0-next.1",
    "@angular/forms": "22.1.0-next.1",
    "@angular/platform-browser": "22.1.0-next.1",
    "@angular/router": "22.1.0-next.1",
    "@elastic/elasticsearch": "^9.4.2",
    "@fontsource-variable/cascadia-code": "^5.2.2",
    "@fontsource-variable/material-symbols-rounded": "^5.2.45",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hey-api/openapi-ts": "^0.98.2",
    "@ngrx/signals": "^21.1.1",
    "@signality/core": "^0.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "idb-keyval": "^6.2.5",
    "ngxtension": "^7.2.0",
    "rxjs": "~7.8.2",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "22.1.0-next.0",
    "@angular/cli": "22.1.0-next.0",
    "@angular/compiler-cli": "22.1.0-next.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/angular": "^19.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "angular-eslint": "^22.0.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
